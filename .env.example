# AgentDeck Web Gateway
HOST=127.0.0.1
PORT=3842
DATA_DIR=/var/lib/agentdeck
ADMIN_PASSWORD=change-me-at-least-12-chars
COOKIE_SECRET=replace-with-a-stable-random-secret
ALLOWED_ORIGINS=http://localhost:3842,http://127.0.0.1:3842
ALLOWED_WORKSPACES=/opt/projects

# AgentDeck Runtime
USE_AGENT_RUNTIME=1
AGENT_RUNTIME_URL=http://127.0.0.1:3852
RUNTIME_HOST=127.0.0.1
RUNTIME_PORT=3852
RUNTIME_DB=/var/lib/agentdeck/agentdeck-runtime.sqlite3
# Set both values when Runtime is not loopback-only.
# RUNTIME_TOKEN=replace-with-random-token
# AGENT_RUNTIME_TOKEN=replace-with-random-token

# Providers
CODEX_HOME=/var/lib/agentdeck/home/.codex
CLAUDE_PROFILE_ROOT=/var/lib/agentdeck/claude/profiles
CLAUDE_CONFIG_DIR=/var/lib/agentdeck/home/.claude
# Optional absolute executable override. Leave unset to use the SDK default.
# CLAUDE_BIN=/usr/local/bin/claude
ANTIGRAVITY_BIN=/home/ubuntu/.local/bin/agy
GEMINI_BIN=/usr/bin/gemini
GEMINI_ACP_ARGS=--acp
GEMINI_PROFILE_ROOT=/var/lib/agentdeck/gemini/profiles/default

# Attachments
MAX_ATTACHMENT_BYTES=33554432
MAX_ATTACHMENTS_PER_MESSAGE=10
MAX_TOTAL_ATTACHMENT_BYTES=67108864
