HOST=127.0.0.1
PORT=3842
DATA_DIR=/var/lib/agentdeck
PATH=/opt/data/agentdeck/provider-tools/bin:/home/ubuntu/.local/bin:/usr/local/bin:/usr/bin:/bin
PLAYWRIGHT_BROWSERS_PATH=/opt/data/agentdeck/cache/ms-playwright
ADMIN_PASSWORD=change-me-at-least-12-chars
COOKIE_SECRET=change-me-random-32-bytes
ALLOWED_ORIGINS=https://agentdeck.example.com
USE_AGENT_RUNTIME=1
AGENT_RUNTIME_URL=http://127.0.0.1:3852
CLAUDE_PROFILE_ROOT=/opt/data/agentdeck/claude/profiles
CLAUDE_CONFIG_DIR=/home/ubuntu/.claude
# CLAUDE_BIN=/usr/local/bin/claude
ANTIGRAVITY_BIN=/home/ubuntu/.local/bin/agy
