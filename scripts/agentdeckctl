#!/usr/bin/env bash
# shellcheck disable=SC2012,SC2015,SC2016,SC2295
set -euo pipefail

CONTROL_ROOT="${AGENTDECK_ROOT:-/opt/stacks/agentdeck}"
SOURCE_ROOT="${AGENTDECK_SOURCE_ROOT:-$CONTROL_ROOT}"
DATA_DIR="${DATA_DIR:-/opt/data/agentdeck}"
ENV_DIR="${AGENTDECK_ENV_DIR:-${ENV_DIR:-/etc/agentdeck}}"
STATE_DIR="${AGENTDECK_DEPLOY_STATE_DIR:-$CONTROL_ROOT/deploy-state}"
RELEASES_DIR="$CONTROL_ROOT/releases"
CURRENT_LINK="$CONTROL_ROOT/current"
PREVIOUS_LINK="$CONTROL_ROOT/previous"
CANDIDATE_LINK="$CONTROL_ROOT/candidate"
CURRENT_WEB_LINK="$CONTROL_ROOT/current-web"
PREVIOUS_WEB_LINK="$CONTROL_ROOT/previous-web"
CANDIDATE_WEB_LINK="$CONTROL_ROOT/candidate-web"
CURRENT_RUNTIME_LINK="$CONTROL_ROOT/current-runtime"
PREVIOUS_RUNTIME_LINK="$CONTROL_ROOT/previous-runtime"
CANDIDATE_RUNTIME_LINK="$CONTROL_ROOT/candidate-runtime"
JOBS_DIR="$STATE_DIR/jobs"
LOG_DIR="$STATE_DIR/logs"
LOCK_FILE="$STATE_DIR/deploy.lock"
WEB_PORT="${AGENTDECK_WEB_PORT:-3842}"
WEB_CANDIDATE_PORT="${AGENTDECK_WEB_CANDIDATE_PORT:-3942}"
RUNTIME_PORT="${AGENTDECK_RUNTIME_PORT:-3852}"
RUNTIME_CANDIDATE_PORT="${AGENTDECK_RUNTIME_CANDIDATE_PORT:-3952}"
DRAIN_TIMEOUT_SECONDS="${AGENTDECK_DRAIN_TIMEOUT_SECONDS:-7200}"
DRAIN_LEASE_SECONDS="${AGENTDECK_DRAIN_LEASE_SECONDS:-120}"
RUNTIME_STOP_TIMEOUT_SECONDS=660
KEEP_RELEASES="${AGENTDECK_KEEP_RELEASES:-5}"
SYSTEMD_UNIT_VERSION=2
SERVICE_USER=""
SERVICE_HOME=""
CREATED_RELEASE_ID=""
PLAYWRIGHT_BROWSERS_PATH="${PLAYWRIGHT_BROWSERS_PATH:-$DATA_DIR/cache/ms-playwright}"
NPM_CONFIG_CACHE="${NPM_CONFIG_CACHE:-$DATA_DIR/cache/npm}"
export PATH="$DATA_DIR/provider-tools/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}"
source "$SOURCE_ROOT/scripts/candidate-lifecycle.sh"

usage() {
  cat >&2 <<'EOF'
usage: sudo agentdeckctl <command> [target] [options]

commands:
  status [--json]
  check
  doctor
  install-units [--runtime-drop-in]
  backup [--include-secrets]
  restore <backup.tar.zst> [--dry-run] [--force]
  restart web|runtime|all [--force]
  deploy web|runtime|all [--wait] [--force]
  rollback web|runtime|all [--wait] [--force]
  jobs
  job <job-id>
  logs deploy
EOF
}

log() { printf '[agentdeckctl] %s\n' "$*" >&2; }
die() { echo "ERROR: $*" >&2; exit 1; }
json_escape() { node -e 'process.stdout.write(JSON.stringify(process.argv[1] || ""))' "$1"; }
is_worker() { [ "${AGENTDECK_DEPLOY_WORKER:-0}" = "1" ]; }
backup_dir() { printf '%s\n' "${AGENTDECK_BACKUP_DIR:-$DATA_DIR/backups}"; }
env_value() { sed -n "s/^[[:space:]]*$2[[:space:]]*=[[:space:]]*['\"]\{0,1\}\([^'\"#]*\).*/\1/p" "$1" | tail -1; }

resolve_service_user() {
  if [ -n "$SERVICE_USER" ]; then return 0; fi
  SERVICE_USER="${AGENTDECK_SERVICE_USER:-${AGENTDECK_RUN_USER:-}}"
  if [ -z "$SERVICE_USER" ] && command -v systemctl >/dev/null 2>&1; then
    SERVICE_USER="$(systemctl show agentdeck-runtime.service -p User --value 2>/dev/null || true)"
  fi
  if [ -z "$SERVICE_USER" ] && [ -f "$ENV_DIR/runtime.env" ]; then
    SERVICE_USER="$(node - "$ENV_DIR/runtime.env" <<'NODE'
const fs = require('node:fs');
const file = process.argv[2];
for (const line of fs.readFileSync(file, 'utf8').split(/\r?\n/)) {
  const m = line.match(/^\s*AGENTDECK_SERVICE_USER\s*=\s*([^#\s]+)/);
  if (m) { console.log(m[1].replace(/^['"]|['"]$/g, '')); process.exit(0); }
}
NODE
)"
  fi
  [ -n "$SERVICE_USER" ] || die "cannot determine AgentDeck service user; set AGENTDECK_SERVICE_USER or install systemd units first"
  SERVICE_HOME="$(getent passwd "$SERVICE_USER" | cut -d: -f6 || true)"
  [ -n "$SERVICE_HOME" ] || die "service user does not exist: $SERVICE_USER"
}

service_env() {
  resolve_service_user
  printf 'HOME=%s\nUSER=%s\nLOGNAME=%s\nPATH=%s\nnpm_config_cache=%s\nNPM_CONFIG_CACHE=%s\nPLAYWRIGHT_BROWSERS_PATH=%s\nDATA_DIR=%s\n' \
    "$SERVICE_HOME" "$SERVICE_USER" "$SERVICE_USER" "$DATA_DIR/provider-tools/bin:/usr/local/bin:/usr/bin:/bin:$SERVICE_HOME/.local/bin" \
    "$NPM_CONFIG_CACHE" "$NPM_CONFIG_CACHE" "$PLAYWRIGHT_BROWSERS_PATH" "$DATA_DIR"
}

run_as_service_user() {
  resolve_service_user
  local -a env_args=()
  mapfile -t env_args < <(service_env)
  if [ "$(id -un)" = "$SERVICE_USER" ]; then
    env "${env_args[@]}" "$@"
  elif command -v runuser >/dev/null 2>&1; then
    runuser -u "$SERVICE_USER" -- env "${env_args[@]}" "$@"
  else
    sudo -H -u "$SERVICE_USER" env "${env_args[@]}" "$@"
  fi
}

ensure_service_owned_dirs() {
  resolve_service_user || return $?
  mkdir -p "$DATA_DIR/cache" "$PLAYWRIGHT_BROWSERS_PATH" "$NPM_CONFIG_CACHE" "$DATA_DIR/provider-tools/bin" "$DATA_DIR/deploy-candidates" "$RELEASES_DIR" "$LOG_DIR" || return $?
  chown -R "$SERVICE_USER:$SERVICE_USER" "$DATA_DIR/cache" "$DATA_DIR/provider-tools" "$DATA_DIR/deploy-candidates" "$LOG_DIR" || return $?
  # Releases are immutable build products.  The builder needs to create entries in
  # the parent, but a running Web/Runtime process must never own existing releases.
  chown "$SERVICE_USER:$SERVICE_USER" "$RELEASES_DIR" || return $?
}

valid_release_id() {
  [[ "$1" =~ ^[0-9]{8}-[0-9]{6}-[A-Za-z0-9._-]{7,40}$ ]]
}

release_path_for() {
  local release_id="$1" path real_parent
  valid_release_id "$release_id" || die "invalid release id: $release_id"
  path="$RELEASES_DIR/$release_id"
  real_parent="$(realpath -m "$RELEASES_DIR")"
  case "$(realpath -m "$path")" in "$real_parent"/*) printf '%s\n' "$path" ;; *) die "release path escapes releases dir: $path" ;; esac
}

safe_rm_tree() {
  local path="$1" root="$2" real_path real_root
  [ -n "$path" ] || return 0
  real_path="$(realpath -m "$path")"
  real_root="$(realpath -m "$root")"
  case "$real_path" in "$real_root"/*) rm -rf "$real_path" ;; *) log "refusing cleanup outside $real_root: $real_path" ;; esac
}

ensure_playwright_browsers() {
  ensure_service_owned_dirs || return $?
  if find "$PLAYWRIGHT_BROWSERS_PATH" -maxdepth 2 -type d -name 'chromium-*' 2>/dev/null | grep -q .; then
    log "Playwright Chromium already present in $PLAYWRIGHT_BROWSERS_PATH"
    return
  fi
  log "installing Playwright Chromium into $PLAYWRIGHT_BROWSERS_PATH as $SERVICE_USER"
  run_as_service_user npx playwright install chromium || return $?
}

ensure_dirs() {
  mkdir -p "$CONTROL_ROOT" "$DATA_DIR" "$STATE_DIR" "$RELEASES_DIR" "$JOBS_DIR" "$LOG_DIR" || return $?
  if [ -L "$CURRENT_LINK" ]; then
    local current_target
    current_target="$(readlink "$CURRENT_LINK")" || return $?
    if [ ! -L "$CURRENT_WEB_LINK" ]; then ln -sfn "$current_target" "$CURRENT_WEB_LINK" || return $?; fi
    if [ ! -L "$CURRENT_RUNTIME_LINK" ]; then ln -sfn "$current_target" "$CURRENT_RUNTIME_LINK" || return $?; fi
  fi
}

write_job() {
  local job_id="$1" status="$2" message="${3:-}"
  node - "$JOBS_DIR/$job_id.json" "$job_id" "$status" "$message" <<'NODE'
const fs = require('node:fs');
const file = process.argv[2], jobId = process.argv[3], status = process.argv[4], message = process.argv[5] || '';
let previous = {};
try { previous = JSON.parse(fs.readFileSync(file, 'utf8')); } catch {}
const now = new Date().toISOString();
const next = { ...previous, id:jobId, status, message, updatedAt:now };
if (!next.createdAt) next.createdAt = now;
if (process.env.AGENTDECK_JOB_COMMAND) next.command = process.env.AGENTDECK_JOB_COMMAND;
if (process.env.AGENTDECK_JOB_TARGET) next.target = process.env.AGENTDECK_JOB_TARGET;
if (process.env.AGENTDECK_JOB_LOG) next.log = process.env.AGENTDECK_JOB_LOG;
if (process.env.AGENTDECK_JOB_RELEASE) next.release = process.env.AGENTDECK_JOB_RELEASE;
fs.writeFileSync(file, JSON.stringify(next, null, 2) + '\n');
NODE
}

latest_job_file() {
  ls -1t "$JOBS_DIR"/*.json 2>/dev/null | head -1 || true
}

show_job() {
  local id="$1"
  [ -f "$JOBS_DIR/$id.json" ] || die "job not found: $id"
  cat "$JOBS_DIR/$id.json"
}

list_jobs() {
  ensure_dirs
  ls -1t "$JOBS_DIR"/*.json 2>/dev/null | while read -r file; do
    node - "$file" <<'NODE'
const fs = require('node:fs');
const j = JSON.parse(fs.readFileSync(process.argv[2], 'utf8'));
console.log(`${j.id}\t${j.status}\t${j.command || ''}\t${j.target || ''}\t${j.updatedAt || ''}`);
NODE
  done
}

service_state() {
  local unit="$1"
  systemctl show "$unit" -p ActiveState -p SubState -p MainPID --value 2>/dev/null | paste -sd ' ' - || true
}

curl_json() {
  local url="$1"
  curl -fsS --max-time 5 "$url"
}

runtime_state() {
  curl_json "http://127.0.0.1:$RUNTIME_PORT/admin/runtime/state" 2>/dev/null || echo '{}'
}

active_turns() {
  curl_json "http://127.0.0.1:$RUNTIME_PORT/admin/runtime/active-turns"
}

active_turn_count_from_json() {
  node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{try{const j=JSON.parse(s); if(!Number.isFinite(Number(j.activeTurnCount))) throw new Error("missing activeTurnCount"); console.log(Number(j.activeTurnCount));}catch(e){console.error(`active-turn query parse failed: ${e.message}`); process.exit(1);}})'
}

drain_status() {
  curl_json "http://127.0.0.1:$RUNTIME_PORT/drain/status"
}

drained_from_json() {
  node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{try{const j=JSON.parse(s);if(typeof j.drained!=="boolean")throw new Error("missing drained boolean");console.log(j.drained?"true":"false");}catch(e){console.error(`drain status parse failed: ${e.message}`);process.exit(1);}})'
}

release_target() {
  local link="$1"
  [ -L "$link" ] && readlink -f "$link" || true
}

require_git_source_root() {
  local git_root
  command -v git >/dev/null 2>&1 || return 127
  git_root="$(git -c "safe.directory=$SOURCE_ROOT" -C "$SOURCE_ROOT" rev-parse --show-toplevel 2>/dev/null)" || return $?
  [ -n "$git_root" ] || return 1
  SOURCE_ROOT="$git_root"
}

status_json() {
  ensure_dirs
  local current previous candidate current_web previous_web candidate_web current_runtime previous_runtime candidate_runtime web runtime last_job db
  current="$(release_target "$CURRENT_LINK")"
  previous="$(release_target "$PREVIOUS_LINK")"
  candidate="$(release_target "$CANDIDATE_LINK")"
  current_web="$(release_target "$CURRENT_WEB_LINK")"; previous_web="$(release_target "$PREVIOUS_WEB_LINK")"; candidate_web="$(release_target "$CANDIDATE_WEB_LINK")"
  current_runtime="$(release_target "$CURRENT_RUNTIME_LINK")"; previous_runtime="$(release_target "$PREVIOUS_RUNTIME_LINK")"; candidate_runtime="$(release_target "$CANDIDATE_RUNTIME_LINK")"
  web="$(curl_json "http://127.0.0.1:$WEB_PORT/api/status" 2>/dev/null || echo '{}')"
  runtime="$(runtime_state)"
  last_job="$(latest_job_file)"
  db="${RUNTIME_DB:-$DATA_DIR/agentdeck-runtime.sqlite3}"
  node - "$current" "$previous" "$candidate" "$current_web" "$previous_web" "$candidate_web" "$current_runtime" "$previous_runtime" "$candidate_runtime" "$web" "$runtime" "$last_job" "$db" "$CURRENT_LINK" "$SOURCE_ROOT" <<'NODE'
const fs = require('node:fs');
const cp = require('node:child_process');
const path = require('node:path');
const [current, previous, candidate, currentWeb, previousWeb, candidateWeb, currentRuntime, previousRuntime, candidateRuntime, webRaw, runtimeRaw, lastJobFile, db, currentLink, sourceRoot] = process.argv.slice(2);
const parse = s => { try { return JSON.parse(s || '{}'); } catch { return {}; } };
let lastJob = null;
if (lastJobFile) try { lastJob = JSON.parse(fs.readFileSync(lastJobFile, 'utf8')); } catch {}
const manifest = release => {
  if (!release) return {};
  try { return JSON.parse(fs.readFileSync(path.join(release, 'deploy-manifest.json'), 'utf8')); } catch { return {}; }
};
const currentManifest = manifest(current);
const originMain = (() => {
  try { return cp.execFileSync('git', ['-c', `safe.directory=${sourceRoot}`, '-C', sourceRoot, 'rev-parse', 'origin/main'], { encoding:'utf8', stdio:['ignore','pipe','ignore'] }).trim() || null; } catch { return null; }
})();
const service = unit => {
  try {
    const out = cp.execFileSync('systemctl', ['show', unit, '-p', 'ActiveState', '-p', 'SubState', '-p', 'MainPID', '--value'], { encoding:'utf8' }).trim().split(/\n/);
    return { activeState:out[0] || 'unknown', subState:out[1] || '', mainPid:Number(out[2] || 0) };
  } catch { return { activeState:'unknown', subState:'', mainPid:0 }; }
};
const web = parse(webRaw);
const runtime = parse(runtimeRaw);
const currentCommit = currentManifest.sourceCommit || currentManifest.commit || runtime.commit || web.release?.commit || null;
console.log(JSON.stringify({
  currentRelease: current || null,
  previousRelease: previous || null,
  candidateRelease: candidate || null,
  componentReleases: {
    web:{current:currentWeb||null,previous:previousWeb||null,candidate:candidateWeb||null},
    runtime:{current:currentRuntime||null,previous:previousRuntime||null,candidate:candidateRuntime||null},
  },
  currentSymlink: currentLink,
  gitCommit: currentCommit,
  sourceRoot: currentManifest.sourceRoot || sourceRoot || null,
  sourceBranch: currentManifest.sourceBranch || null,
  originMainCommit: originMain,
  releaseManifest: currentManifest,
  web: { pid:service('agentdeck-web.service').mainPid, port:Number(process.env.AGENTDECK_WEB_PORT || 3842), version:web.release || null },
  runtime: { pid:service('agentdeck-runtime.service').mainPid, port:Number(process.env.AGENTDECK_RUNTIME_PORT || 3852), state:runtime },
  activeTurnCount:Number(runtime.activeTurnCount || 0),
  draining:runtime.lifecycle === 'draining' || runtime.state === 'draining',
  providers: { codexAppServerDefault:service('agentdeck-app-server@default.service') },
  lastJob,
  lastDeploySucceeded:lastJob ? lastJob.status === 'succeeded' : null,
  databasePath:db,
  services: {
    web:service('agentdeck-web.service'),
    runtime:service('agentdeck-runtime.service'),
    codexDefault:service('agentdeck-app-server@default.service'),
  },
}, null, 2));
NODE
}

status_text() {
  local json
  json="$(status_json)"
  node - "$json" <<'NODE'
const s = JSON.parse(process.argv[2]);
console.log(`current:  ${s.currentRelease || '-'}`);
console.log(`previous: ${s.previousRelease || '-'}`);
console.log(`candidate:${s.candidateRelease || '-'}`);
for (const name of ['web','runtime']) { const r=s.componentReleases[name]; console.log(`${name} releases: current=${r.current||'-'} previous=${r.previous||'-'} candidate=${r.candidate||'-'}`); }
console.log(`commit:   ${s.gitCommit || '-'}`);
console.log(`source:   ${s.sourceRoot || '-'}`);
if (s.originMainCommit) console.log(`origin:   ${s.originMainCommit}`);
console.log(`web:      pid=${s.web.pid || 0} port=${s.web.port} service=${s.services.web.activeState}/${s.services.web.subState}`);
console.log(`runtime:  pid=${s.runtime.pid || 0} port=${s.runtime.port} state=${s.runtime.state.state || 'unknown'} activeTurns=${s.activeTurnCount} draining=${s.draining}`);
console.log(`provider: codex-default pid=${s.providers.codexAppServerDefault.mainPid || 0} service=${s.providers.codexAppServerDefault.activeState}/${s.providers.codexAppServerDefault.subState}`);
console.log(`db:       ${s.databasePath}`);
console.log(`symlink:  ${s.currentSymlink}`);
if (s.lastJob) console.log(`last job: ${s.lastJob.id} ${s.lastJob.status} ${s.lastJob.command || ''} ${s.lastJob.target || ''}`);
NODE
}

run_check() {
  ensure_dirs
  resolve_service_user
  cd "$SOURCE_ROOT"
  log "checking Node and npm"
  run_as_service_user node --version
  run_as_service_user npm --version
  log "checking env dir"
  [ -d "$ENV_DIR" ] || die "env dir does not exist: $ENV_DIR"
  for name in web.env runtime.env agentdeck-app-server-default.env; do
    [ -f "$ENV_DIR/$name" ] || die "missing env file: $ENV_DIR/$name"
  done
  local web_data runtime_data runtime_home runtime_user provider_home provider_bin admin_password cookie_secret
  web_data="$(env_value "$ENV_DIR/web.env" DATA_DIR)"; runtime_data="$(env_value "$ENV_DIR/runtime.env" DATA_DIR)"
  runtime_home="$(env_value "$ENV_DIR/runtime.env" HOME)"; runtime_user="$(env_value "$ENV_DIR/runtime.env" AGENTDECK_SERVICE_USER)"
  provider_home="$(env_value "$ENV_DIR/agentdeck-app-server-default.env" HOME)"
  admin_password="$(env_value "$ENV_DIR/web.env" ADMIN_PASSWORD)"; cookie_secret="$(env_value "$ENV_DIR/web.env" COOKIE_SECRET)"
  [ "$web_data" = "$DATA_DIR" ] && [ "$runtime_data" = "$DATA_DIR" ] || die "Web/Runtime DATA_DIR mismatch: expected $DATA_DIR, web=$web_data runtime=$runtime_data"
  [ "$runtime_user" = "$SERVICE_USER" ] || die "Runtime provider user mismatch: service=$SERVICE_USER configured=$runtime_user"
  [ "$runtime_home" = "$SERVICE_HOME" ] && [ "$provider_home" = "$SERVICE_HOME" ] || die "HOME mismatch: service=$SERVICE_HOME runtime=$runtime_home provider=$provider_home"
  getent passwd "$runtime_user" >/dev/null || die "Provider user does not exist: $runtime_user"
  provider_bin="$(env_value "$ENV_DIR/runtime.env" CODEX_BIN)"; [ -z "$provider_bin" ] || [ -x "$provider_bin" ] || die "Provider binary is not executable: $provider_bin"
  case "$admin_password" in change-me|change-me-at-least-12-chars|'') die "ADMIN_PASSWORD still uses an unsafe default" ;; esac
  case "$cookie_secret" in change-me|change-me-random-32-bytes|'') die "COOKIE_SECRET still uses an unsafe default" ;; esac
  log "checking service user and data dirs"
  [ -d "$DATA_DIR" ] || die "data dir does not exist: $DATA_DIR"
  [ -d "$RELEASES_DIR" ] || die "releases dir does not exist: $RELEASES_DIR"
  [ -L "$CURRENT_WEB_LINK" ] || die "current-web symlink is missing: $CURRENT_WEB_LINK"
  [ -L "$CURRENT_RUNTIME_LINK" ] || die "current-runtime symlink is missing: $CURRENT_RUNTIME_LINK"
  check_systemd_units "$SOURCE_ROOT" fail
  log "checking production health"
  wait_http "http://127.0.0.1:$WEB_PORT/api/status" 10
  wait_http "http://127.0.0.1:$RUNTIME_PORT/healthz" 10
  log "CHECK_OK commit=$(git -c "safe.directory=$SOURCE_ROOT" -C "$SOURCE_ROOT" rev-parse --short=12 HEAD 2>/dev/null || echo unknown)"
}

run_doctor() {
  if run_check; then
    log "DOCTOR_OK"
  else
    local code=$?
    echo "Suggested next steps:" >&2
    echo "  sudo agentdeckctl install-units" >&2
    echo "  sudo agentdeckctl restart all --force" >&2
    echo "  npm run typecheck && npm run lint && npm test && npm run build" >&2
    return "$code"
  fi
}

render_unit_template() {
  local root="$1" unit="$2" out="$3"
  local run_user run_group home current_dir profile codex_approval_policy codex_sandbox_mode
  run_user="${AGENTDECK_RUN_USER:-ubuntu}"
  run_group="${AGENTDECK_RUN_GROUP:-$run_user}"
  home="${AGENTDECK_HOME:-/home/ubuntu}"
  current_dir="${AGENTDECK_CURRENT_DIR:-$CURRENT_LINK}"
  profile="${AGENTDECK_INSTALL_PROFILE:-personal}"
  case "$profile" in
    standard)
      codex_approval_policy="${AGENTDECK_CODEX_APPROVAL_POLICY:-on-request}"
      codex_sandbox_mode="${AGENTDECK_CODEX_SANDBOX_MODE:-workspace-write}"
      ;;
    hardened)
      codex_approval_policy="${AGENTDECK_CODEX_APPROVAL_POLICY:-on-request}"
      codex_sandbox_mode="${AGENTDECK_CODEX_SANDBOX_MODE:-read-only}"
      ;;
    *)
      codex_approval_policy="${AGENTDECK_CODEX_APPROVAL_POLICY:-never}"
      codex_sandbox_mode="${AGENTDECK_CODEX_SANDBOX_MODE:-danger-full-access}"
      ;;
  esac
  sed \
    -e "s#@AGENTDECK_RUN_USER@#$run_user#g" \
    -e "s#@AGENTDECK_RUN_GROUP@#$run_group#g" \
    -e "s#@AGENTDECK_HOME@#$home#g" \
    -e "s#@AGENTDECK_DATA_DIR@#$DATA_DIR#g" \
    -e "s#@AGENTDECK_CURRENT_DIR@#$current_dir#g" \
    -e "s#@AGENTDECK_ENV_DIR@#$ENV_DIR#g" \
    -e "s#@CODEX_APPROVAL_POLICY@#$codex_approval_policy#g" \
    -e "s#@CODEX_SANDBOX_MODE@#$codex_sandbox_mode#g" \
    "$root/deploy/systemd/$unit" > "$out"
}

check_systemd_units() {
  local root="$1" mode="${2:-warn}" tmpdir unit target outdated=0 missing=0
  log "checking systemd unit files"
  tmpdir="$(mktemp -d)"
  for unit in agentdeck-web.service agentdeck-runtime.service agentdeck-app-server@.service; do
    target="/etc/systemd/system/$unit"
    render_unit_template "$root" "$unit" "$tmpdir/$unit"
    if [ ! -f "$target" ]; then
      echo "ERROR: missing systemd unit: $target" >&2
      missing=1
      continue
    fi
    if ! cmp -s "$tmpdir/$unit" "$target"; then
      echo "WARN: systemd unit is outdated: $target" >&2
      outdated=1
    fi
  done
  if [ "$missing" = "1" ]; then
    echo "Run: sudo agentdeckctl install-units" >&2
  fi
  if [ "$outdated" = "1" ]; then
    echo "systemd units are outdated. Run:" >&2
    echo "  sudo agentdeckctl install-units" >&2
  fi
  rm -rf "$tmpdir"
  [ "$missing" = "1" ] && [ "$mode" = "fail" ] && return 1
  return 0
}

run_install_units() {
  local install_mode="${1:-}"
  ensure_dirs
  echo "Installing/updating systemd units:"
  echo "  agentdeck-web.service"
  echo "  agentdeck-runtime.service"
  echo "  agentdeck-app-server@.service"
  local tmpdir unit
  tmpdir="$(mktemp -d)"
  for unit in agentdeck-web.service agentdeck-runtime.service agentdeck-app-server@.service; do
    render_unit_template "$SOURCE_ROOT" "$unit" "$tmpdir/$unit"
    echo
    echo "Resolved $unit:"
    awk -F= '
      /^(User|Group|WorkingDirectory)=/ { print "  " $1 "=" $2 }
      /^Environment=HOME=/ { sub(/^Environment=/, ""); print "  " $0 }
      /^Environment=DATA_DIR=/ { sub(/^Environment=/, ""); print "  " $0 }
      /^EnvironmentFile=/ { env=$2; sub(/\/[^/]+$/, "", env); print "  ENV_DIR=" env }
    ' "$tmpdir/$unit" | awk '!seen[$0]++'
  done
  rm -rf "$tmpdir"
  ROOT="$SOURCE_ROOT" DATA_DIR="$DATA_DIR" ENV_DIR="$ENV_DIR" "$SOURCE_ROOT/deploy/install-units.sh" $install_mode
}

make_release() {
  local stage_state="$1" job_id="$2"
  ensure_dirs || return $?
  ensure_service_owned_dirs || return $?
  require_git_source_root || return $?
  local commit short branch ts release_id release_path previous_release built_by node_version npm_version
  cd "$SOURCE_ROOT" || return $?
  commit="$(git -c "safe.directory=$SOURCE_ROOT" -C "$SOURCE_ROOT" rev-parse HEAD)" || return $?
  short="$(printf '%s' "$commit" | cut -c1-12)" || return $?
  branch="$(git -c "safe.directory=$SOURCE_ROOT" -C "$SOURCE_ROOT" branch --show-current 2>/dev/null || true)"
  ts="$(date -u +%Y%m%d-%H%M%S)" || return $?
  release_id="$ts-$short"
  valid_release_id "$release_id" || return $?
  release_path="$(release_path_for "$release_id")" || return $?
  CREATED_RELEASE_ID="$release_id"
  export AGENTDECK_JOB_RELEASE="$release_id"
  deploy_journal_set_value "$stage_state" release_id "$release_id" || return $?
  write_job "$job_id" running "creating release" || return $?
  previous_release="$(release_target "$CURRENT_LINK")"
  built_by="$(id -un 2>/dev/null || whoami 2>/dev/null || echo unknown)"
  [ ! -e "$release_path" ] || die "release already exists: $release_id"
  log "creating release $release_id"
  run_as_service_user git worktree add --detach "$release_path" "$commit" >/dev/null || return $?
  cd "$release_path" || return $?
  ensure_playwright_browsers || return $?
  run_as_service_user npm ci || return $?
  run_as_service_user npm run typecheck || return $?
  run_as_service_user npm run lint || return $?
  run_as_service_user npm run build || return $?
  run_as_service_user npm test || return $?
  run_as_service_user npm run test:e2e || return $?
  node_version="$(run_as_service_user node --version)" || return $?
  npm_version="$(run_as_service_user npm --version)" || return $?
  node - "$release_path/deploy-manifest.json" "$release_id" "$commit" "$SOURCE_ROOT" "$branch" "$previous_release" "$built_by" "$node_version" "$npm_version" "$SYSTEMD_UNIT_VERSION" <<'NODE' || return $?
const fs = require('node:fs');
fs.writeFileSync(process.argv[2], JSON.stringify({
  releaseId:process.argv[3],
  commit:process.argv[4],
  sourceCommit:process.argv[4],
  sourceRoot:process.argv[5],
  sourceBranch:process.argv[6] || null,
  buildTime:new Date().toISOString(),
  builtAt:new Date().toISOString(),
  previousRelease:process.argv[7] || null,
  builtBy:process.argv[8] || null,
  nodeVersion:process.argv[9] || null,
  npmVersion:process.argv[10] || null,
  systemdUnitVersion:Number(process.argv[11] || 0),
  requiredSystemdUnitVersion:Number(process.argv[11] || 0),
  testResultSummary:{
    typecheck:'passed',
    lint:'passed',
    build:'passed',
    unit:'passed',
    e2e:'passed',
  },
  schemaVersion:1,
  apiDtoContractVersion:1,
  compatibility:{ web:true, runtime:true },
}, null, 2) + '\n');
NODE
  ln -sfn "releases/$release_id" "$CANDIDATE_LINK.tmp" || return $?
  mv -Tf "$CANDIDATE_LINK.tmp" "$CANDIDATE_LINK" || return $?
}

assert_release_unit_requirement() {
  local release_path="$1" required
  required="$(node - "$release_path/deploy-manifest.json" "$SYSTEMD_UNIT_VERSION" <<'NODE'
const fs = require('node:fs');
const manifest = JSON.parse(fs.readFileSync(process.argv[2], 'utf8'));
console.log(Number(manifest.requiredSystemdUnitVersion || 0));
NODE
)"
  verify_runtime_systemd_contract "$required"
}

verify_runtime_systemd_contract() {
  local required="${1:-$SYSTEMD_UNIT_VERSION}" properties fragment dropins timeout_us environment actual_version=""
  properties="$(systemctl show agentdeck-runtime.service -p FragmentPath -p DropInPaths -p TimeoutStopUSec -p Environment 2>/dev/null)" || die "cannot read effective agentdeck-runtime.service contract"
  fragment="$(printf '%s\n' "$properties" | sed -n 's/^FragmentPath=//p')"
  dropins="$(printf '%s\n' "$properties" | sed -n 's/^DropInPaths=//p')"
  timeout_us="$(printf '%s\n' "$properties" | sed -n 's/^TimeoutStopUSec=//p')"
  environment="$(printf '%s\n' "$properties" | sed -n 's/^Environment=//p')"
  actual_version="$(printf '%s\n' "$environment" | sed -n 's/.*AGENTDECK_SYSTEMD_UNIT_VERSION=\([0-9][0-9]*\).*/\1/p')"
  [ -n "$fragment" ] || die "effective Runtime unit has no FragmentPath (daemon-reload may be required)"
  if ! [[ "$timeout_us" =~ ^[0-9]+$ ]]; then
    timeout_us="$(node - "$timeout_us" <<'NODE' 2>/dev/null || true
const value=process.argv[2]?.trim();
const units={us:1,'µs':1,ms:1e3,s:1e6,min:60e6,h:3600e6,d:86400e6};
let total=0,end=0,match;const re=/(\d+(?:\.\d+)?)\s*(us|µs|ms|min|s|h|d)/g;
while((match=re.exec(value))){if(value.slice(end,match.index).trim())process.exit(1);total+=Number(match[1])*units[match[2]];end=re.lastIndex;}
if(!end||value.slice(end).trim()||!Number.isFinite(total))process.exit(1);process.stdout.write(String(Math.round(total)));
NODE
)"
  fi
  [[ "$timeout_us" =~ ^[0-9]+$ ]] || die "effective Runtime TimeoutStopUSec is invalid: ${timeout_us:-missing}"
  [ "$timeout_us" -ge $((RUNTIME_STOP_TIMEOUT_SECONDS * 1000000)) ] || die "effective Runtime TimeoutStopUSec=$timeout_us is below Runtime stop contract $((RUNTIME_STOP_TIMEOUT_SECONDS * 1000000))us"
  [[ "$actual_version" =~ ^[0-9]+$ ]] || die "effective Runtime unit contract version is missing (fragment=$fragment drop-ins=${dropins:-none}); run daemon-reload after install-units"
  [ "$actual_version" -ge "$required" ] || die "effective Runtime unit contract version $actual_version is older than required $required (fragment=$fragment drop-ins=${dropins:-none})"
  log "effective Runtime contract ok: version=$actual_version timeoutStopUSec=$timeout_us fragment=$fragment drop-ins=${dropins:-none}"
}

sqlite_backup() {
  local source_db="${RUNTIME_DB:-$DATA_DIR/agentdeck-runtime.sqlite3}" dest_db="$1"
  mkdir -p "$(dirname "$dest_db")"
  if [ ! -f "$source_db" ]; then
    : > "$dest_db"
    return
  fi
  if ! timeout --kill-after=10s 310s node "$SOURCE_ROOT/scripts/sqlite-backup.cjs" "$source_db" "$dest_db"
  then log "live sqlite backup failed; candidate validation cancelled"; return 1; fi
}

candidate_db_mode() {
  local release_path="$1" override="${AGENTDECK_CANDIDATE_DB_MODE:-}"
  case "$override" in minimal|copy) printf '%s\n' "$override"; return ;; '') ;; *) die "invalid AGENTDECK_CANDIDATE_DB_MODE: $override" ;; esac
  # Candidate validation exercises migrations and API contracts on an isolated
  # database. Copying a live, append-heavy events database is opt-in because it
  # can prevent deployment from ever reaching the drain/cutover stage.
  printf 'minimal\n'
}

prepare_candidate_runtime_db() {
  local release_path="$1" candidate_dir="$2" mode
  mode="$(candidate_db_mode "$release_path")"
  log "candidate runtime database mode: $mode"
  case "$mode" in
    minimal) rm -f "$candidate_dir/agentdeck-runtime.sqlite3"* ;;
    copy) sqlite_backup "$candidate_dir/agentdeck-runtime.sqlite3" ;;
    *) die "unsupported candidate database mode: $mode" ;;
  esac
}

sqlite_file_backup() {
  local source_db="$1" dest_db="$2"
  mkdir -p "$(dirname "$dest_db")"
  if [ ! -f "$source_db" ]; then
    return 0
  fi
  if timeout --kill-after=10s 310s node "$SOURCE_ROOT/scripts/sqlite-backup.cjs" "$source_db" "$dest_db"
  then
    return 0
  fi
  die "sqlite online backup failed for $source_db"
}

backup_manifest() {
  local file="$1" include_secrets="$2" root="$3" checksums
  checksums="$root/checksums.tsv"
  : > "$checksums"
  while IFS= read -r -d '' entry; do
    rel="${entry#$root/}"; mode="$(stat -c %a "$entry")"
    if [ -d "$entry" ]; then printf '%s\tdirectory\t%s\t0\t-\n' "$rel" "$mode" >> "$checksums"
    else printf '%s\tfile\t%s\t%s\t%s\n' "$rel" "$mode" "$(stat -c %s "$entry")" "$(sha256sum "$entry" | cut -d' ' -f1)" >> "$checksums"; fi
  done < <(find "$root" -mindepth 1 ! -name manifest.json ! -name checksums.tsv -print0 | sort -z)
  node - "$file" "$SOURCE_ROOT" "$DATA_DIR" "$include_secrets" "${AGENTDECK_INSTALL_PROFILE:-personal}" "$checksums" <<'NODE'
const fs = require('node:fs');
const cp = require('node:child_process');
const [file, sourceRoot, dataDir, includeSecrets, profile, checksums] = process.argv.slice(2);
const pkg = JSON.parse(fs.readFileSync(`${sourceRoot}/package.json`, 'utf8'));
let commit = '';
try { commit = cp.execFileSync('git', ['-c', `safe.directory=${sourceRoot}`, '-C', sourceRoot, 'rev-parse', 'HEAD'], { encoding:'utf8', stdio:['ignore','pipe','ignore'] }).trim(); } catch {}
fs.writeFileSync(file, JSON.stringify({
  version:pkg.version || '0.0.0',
  commit,
  created_at:new Date().toISOString(),
  profile:profile || 'personal',
  data_dir:dataDir,
  included_secrets:includeSecrets === '1',
  entries:fs.readFileSync(checksums,'utf8').trim().split(/\n/).filter(Boolean).map(line=>{const [path,type,mode,size,sha256]=line.split('\t');return{path,type,mode,size:Number(size),...(type==='file'?{sha256}:{})};}),
}, null, 2) + '\n');
NODE
  rm -f "$checksums"
}

redacted_env_summary() {
  local out="$1"
  mkdir -p "$(dirname "$out")"
  node - "$ENV_DIR" "$out" <<'NODE'
const fs = require('node:fs');
const path = require('node:path');
const envDir = process.argv[2], out = process.argv[3];
const sensitive = /token|secret|password|api[_-]?key|cookie|authorization|device[_-]?code|auth[_ -]?code|login[_ -]?url/i;
const summary = {};
for (const name of ['web.env','runtime.env','agentdeck-app-server-default.env']) {
  const file = path.join(envDir, name);
  const values = {};
  try {
    for (const line of fs.readFileSync(file, 'utf8').split(/\r?\n/)) {
      const m = line.match(/^\s*([A-Za-z_][A-Za-z0-9_]*)=(.*)$/);
      if (!m) continue;
      values[m[1]] = sensitive.test(m[1]) ? '[redacted]' : m[2].replace(/^['"]|['"]$/g, '');
    }
  } catch {}
  summary[name] = values;
}
fs.writeFileSync(out, JSON.stringify(summary, null, 2) + '\n');
NODE
}

copy_backup_dir_if_present() {
  local rel="$1" tmp="$2"
  if [ -e "$DATA_DIR/$rel" ]; then
    mkdir -p "$tmp/data/$(dirname "$rel")"
    cp -a "$DATA_DIR/$rel" "$tmp/data/$rel"
  fi
}

run_backup() {
  local include_secrets="$1" out_dir stamp tmp archive
  ensure_dirs
  out_dir="$(backup_dir)"
  stamp="$(date -u +%Y%m%d-%H%M%S)"
  archive="$out_dir/agentdeck-backup-$stamp.tar.zst"
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' RETURN
  mkdir -p "$out_dir" "$tmp/data"
  if [ "$include_secrets" = "1" ]; then
    echo "WARNING: --include-secrets will include provider tokens, OAuth state, API keys, and local profile secrets." >&2
    echo "Store this backup like a password vault." >&2
  fi
  sqlite_file_backup "$DATA_DIR/agentdeck.sqlite3" "$tmp/data/agentdeck.sqlite3"
  sqlite_file_backup "${RUNTIME_DB:-$DATA_DIR/agentdeck-runtime.sqlite3}" "$tmp/data/agentdeck-runtime.sqlite3"
  for rel in attachments artifacts shared/generated_images provider-tools; do
    copy_backup_dir_if_present "$rel" "$tmp"
  done
  if [ "$include_secrets" = "1" ]; then
    for rel in profiles claude/profiles gemini/profiles antigravity-profiles shared/sessions; do
      copy_backup_dir_if_present "$rel" "$tmp"
    done
  fi
  redacted_env_summary "$tmp/redacted-env-summary.json"
  backup_manifest "$tmp/manifest.json" "$include_secrets" "$tmp"
  tar -C "$tmp" --zstd -cf "$archive" .
  tar --zstd -tf "$archive" >/dev/null
  [ "$include_secrets" = "1" ] && chmod 0600 "$archive" || chmod 0640 "$archive"
  echo "$archive"
}

restore_usage() {
  echo "usage: sudo agentdeckctl restore <agentdeck-backup-YYYYMMDD-HHMMSS.tar.zst> [--dry-run] [--force]" >&2
}

restore_content_list() {
  local tmp="$1"
  find "$tmp" -mindepth 1 -maxdepth 3 -print | sed "s#^$tmp/##" | sort
}

run_restore() {
  local archive="$1" dry_run="$2" force="$3" tmp included_secrets rollback_root staging
  [ -n "$archive" ] || { restore_usage; exit 2; }
  [ -f "$archive" ] || die "backup file not found: $archive"
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' RETURN
  if tar --zstd -tvf "$archive" | awk '{p=$NF; if(p ~ /^\// || p ~ /(^|\/)\.\.($|\/)/ || $1 ~ /^[lbcps]/) bad=1} END{exit bad?1:0}'; then :; else die "backup contains unsafe path, link, or special file"; fi
  tar -C "$tmp" --zstd -xf "$archive"
  [ -f "$tmp/manifest.json" ] || { rm -rf "$tmp"; die "backup manifest.json is missing"; }
  node - "$tmp/manifest.json" "$tmp" <<'NODE'
const fs=require('node:fs'),crypto=require('node:crypto'),path=require('node:path');const [manifestFile,root]=process.argv.slice(2);const manifest=JSON.parse(fs.readFileSync(manifestFile));
const declared=new Set(['manifest.json']);
for(const entry of manifest.entries||[]){if(path.isAbsolute(entry.path)||entry.path.split(/[\\/]/).includes('..'))throw new Error('unsafe manifest path');declared.add(entry.path);const target=path.join(root,entry.path);const st=fs.lstatSync(target);if(entry.type==='directory'){if(!st.isDirectory())throw new Error(`backup type mismatch: ${entry.path}`);}else{if(!st.isFile())throw new Error(`backup type mismatch: ${entry.path}`);const data=fs.readFileSync(target);if(data.length!==entry.size||crypto.createHash('sha256').update(data).digest('hex')!==entry.sha256)throw new Error(`backup checksum mismatch: ${entry.path}`);}if((st.mode&0o777).toString(8)!==String(entry.mode).replace(/^0+/,''))throw new Error(`backup mode mismatch: ${entry.path}`);}
function walk(dir){for(const name of fs.readdirSync(dir)){const full=path.join(dir,name),rel=path.relative(root,full).split(path.sep).join('/');if(!declared.has(rel))throw new Error(`undeclared backup entry: ${rel}`);if(fs.lstatSync(full).isDirectory())walk(full);}}walk(root);
NODE
  for database in "$tmp/data/agentdeck.sqlite3" "$tmp/data/agentdeck-runtime.sqlite3"; do [ ! -f "$database" ] || node - "$database" <<'NODE'
const Database=require('better-sqlite3');const db=new Database(process.argv[2],{readonly:true,fileMustExist:true});const result=db.pragma('integrity_check');db.close();if(result.length!==1||result[0].integrity_check!=='ok')throw new Error('sqlite integrity_check failed');
NODE
  done
  echo "Backup manifest:"
  cat "$tmp/manifest.json"
  echo
  echo "Will restore:"
  restore_content_list "$tmp"
  included_secrets="$(node - "$tmp/manifest.json" <<'NODE'
const fs = require('node:fs');
const m = JSON.parse(fs.readFileSync(process.argv[2], 'utf8'));
console.log(m.included_secrets ? '1' : '0');
NODE
)"
  if [ "$dry_run" = "1" ]; then
    if [ "$included_secrets" = "1" ]; then echo "Secrets policy: replace all managed secret paths from the archive."; else echo "Secrets policy: preserve existing profiles, provider account stores, and shared/sessions; restore no secrets from this archive."; fi
    rm -rf "$tmp"
    return 0
  fi
  for rel in agentdeck.sqlite3 agentdeck-runtime.sqlite3 attachments artifacts shared/generated_images profiles claude/profiles gemini/profiles antigravity-profiles shared/sessions; do
    if [ -e "$tmp/data/$rel" ] && [ -e "$DATA_DIR/$rel" ]; then
      [ "$force" = "1" ] || { rm -rf "$tmp"; die "target data exists in $DATA_DIR; rerun with --force to overwrite"; }
    fi
  done
  echo "WARNING: restoring will overwrite AgentDeck data in $DATA_DIR." >&2
  [ "$force" = "1" ] || { rm -rf "$tmp"; die "restore requires --force"; }
  resolve_service_user
  staging="$tmp/restore-root"; mkdir -p "$staging"
  if [ "$included_secrets" != "1" ] && [ -d "$DATA_DIR" ]; then
    for rel in profiles claude/profiles gemini/profiles antigravity-profiles shared/sessions; do
      if [ -e "$DATA_DIR/$rel" ]; then mkdir -p "$staging/$(dirname "$rel")"; cp -a "$DATA_DIR/$rel" "$staging/$rel"; fi
    done
  fi
  cp -a "$tmp/data/." "$staging/"
  chown -R "$SERVICE_USER:$SERVICE_USER" "$staging"
  rollback_root="${DATA_DIR}.rollback-$(date -u +%Y%m%d-%H%M%S)"
  drain_runtime
  wait_drain 0
  require_runtime_drained
  systemctl stop agentdeck-web.service agentdeck-runtime.service
  if [ -e "$DATA_DIR" ]; then mv "$DATA_DIR" "$rollback_root"; else mkdir -p "$(dirname "$DATA_DIR")"; rollback_root=""; fi
  if mv "$staging" "$DATA_DIR" && systemctl start agentdeck-runtime.service && wait_http "http://127.0.0.1:$RUNTIME_PORT/healthz" 45 && systemctl start agentdeck-web.service && wait_http "http://127.0.0.1:$WEB_PORT/api/status" 45; then
    echo "Restore complete. Rollback snapshot: ${rollback_root:-none (target was empty)}"
  else
    systemctl stop agentdeck-web.service agentdeck-runtime.service || true
    rm -rf "$DATA_DIR"
    [ -z "$rollback_root" ] || mv "$rollback_root" "$DATA_DIR"
    systemctl start agentdeck-runtime.service agentdeck-web.service || true
    die "restore health check failed; original data restored"
  fi
}

start_candidate_runtime() {
  local release_path="$1" job_id="$2" candidate_dir pid_file
  candidate_dir="$DATA_DIR/deploy-candidates/$job_id"
  pid_file="$candidate_dir/runtime.pid"
  mkdir -p "$candidate_dir"
  chown -R "$SERVICE_USER:$SERVICE_USER" "$candidate_dir"
  prepare_candidate_runtime_db "$release_path" "$candidate_dir"
  chown "$SERVICE_USER:$SERVICE_USER" "$candidate_dir/agentdeck-runtime.sqlite3" 2>/dev/null || true
  run_as_service_user bash -c 'cd "$1"; RUNTIME_MODE=candidate DATA_DIR="$2" RUNTIME_DATA_DIR="$2" RUNTIME_DB="$2/agentdeck-runtime.sqlite3" RUNTIME_PORT="$3" RUNTIME_HOST=127.0.0.1 AGENTDECK_RELEASE_ID="$4" node server/dist/agentdeck-runtime.js >>"$5" 2>&1 & echo $! > "$6"' _ "$release_path" "$candidate_dir" "$RUNTIME_CANDIDATE_PORT" "$(basename "$release_path")" "$LOG_DIR/$job_id.candidate-runtime.log" "$pid_file"
  wait_http "http://127.0.0.1:$RUNTIME_CANDIDATE_PORT/healthz" 30
  curl -fsS "http://127.0.0.1:$RUNTIME_CANDIDATE_PORT/schema" >/dev/null
  curl -fsS "http://127.0.0.1:$RUNTIME_CANDIDATE_PORT/internal/deep-health" | node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{const j=JSON.parse(s);if(!j.ok||j.mode!=="candidate"||!j.candidateRejectsTurns||!j.sqlite)process.exit(1);})'
  local turn_status
  turn_status="$(curl -sS -o /dev/null -w '%{http_code}' -X POST -H 'content-type: application/json' --data '{"text":"candidate smoke must be rejected"}' "http://127.0.0.1:$RUNTIME_CANDIDATE_PORT/sessions/candidate-smoke/turns")"
  [ "$turn_status" = "503" ] || die "candidate runtime accepted or mishandled a real turn: HTTP $turn_status"
}

start_candidate_web() {
  local release_path="$1" job_id="$2" expected_runtime_release="$3" candidate_dir pid_file
  candidate_dir="$DATA_DIR/deploy-candidates/$job_id"
  pid_file="$candidate_dir/web.pid"
  mkdir -p "$candidate_dir"
  chown -R "$SERVICE_USER:$SERVICE_USER" "$candidate_dir"
  rm -f "$candidate_dir/agentdeck.sqlite3"*
  if [ "${AGENTDECK_CANDIDATE_DB_MODE:-minimal}" = "copy" ]; then
    sqlite_file_backup "$DATA_DIR/agentdeck.sqlite3" "$candidate_dir/agentdeck.sqlite3"
  fi
  chown -R "$SERVICE_USER:$SERVICE_USER" "$candidate_dir"
  run_as_service_user bash -c 'set -a; [ -f "$8" ] && . "$8"; set +a; cd "$1"; PORT="$2" DATA_DIR="$3" ADMIN_PASSWORD=agentdeck-candidate-smoke-only SMOKE_TEST_MODE=1 USE_AGENT_RUNTIME=1 AGENT_RUNTIME_URL="$4" AGENTDECK_RELEASE_ID="$5" node server/dist/index.js >>"$6" 2>&1 & echo $! > "$7"' _ "$release_path" "$WEB_CANDIDATE_PORT" "$candidate_dir" "http://127.0.0.1:$RUNTIME_CANDIDATE_PORT" "$(basename "$release_path")" "$LOG_DIR/$job_id.candidate-web.log" "$pid_file" "$ENV_DIR/web.env"
  wait_http "http://127.0.0.1:$WEB_CANDIDATE_PORT/internal/deep-health" 30
  curl -fsS "http://127.0.0.1:$WEB_CANDIDATE_PORT/internal/deep-health" | node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{const j=JSON.parse(s),web=process.argv[1],runtime=process.argv[2];if(!j.ok||!j.sqlite||!j.runtimeConnected||!j.compatible||j.releaseId!==web||j.runtimeReleaseId!==runtime||j.runtimeMode!=="candidate")process.exit(1);})' "$(basename "$release_path")" "$expected_runtime_release"
}

validate_candidate_runtime_compatibility(){
  local current_web expected
  current_web="$(release_target "$CURRENT_WEB_LINK")"; [ -n "$current_web" ] || die "current Web release is missing"
  expected="$(node - "$current_web/deploy-manifest.json" <<'NODE'
const fs=require('node:fs');try{const m=JSON.parse(fs.readFileSync(process.argv[2]));process.stdout.write(String(m.apiDtoContractVersion||1));}catch{process.stdout.write('1');}
NODE
)"
  curl -fsS "http://127.0.0.1:$RUNTIME_CANDIDATE_PORT/internal/deep-health" | node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{const j=JSON.parse(s);if(!j.ok||Number(j.contractVersion)!==Number(process.argv[1]))process.exit(1);})' "$expected"
}

wait_http() {
  local url="$1" seconds="$2" start
  start="$(date +%s)"
  until curl -fsS "$url" >/dev/null 2>&1; do
    [ $(( $(date +%s) - start )) -lt "$seconds" ] || die "health check timed out: $url"
    sleep 1
  done
}

switch_component() {
  local component="$1" release_id="$2" current previous
  if [ "$component" = "web" ]; then current="$CURRENT_WEB_LINK"; previous="$PREVIOUS_WEB_LINK"; else current="$CURRENT_RUNTIME_LINK"; previous="$PREVIOUS_RUNTIME_LINK"; fi
  local current_target
  if [ -L "$current" ]; then current_target="$(readlink "$current")" || return $?; elif [ -e "$current" ]; then return 1; else current_target=""; fi
  if [ -n "$current_target" ]; then
    ln -sfn "$current_target" "$previous.tmp" || return $?
    mv -Tf "$previous.tmp" "$previous" || return $?
  fi
  ln -sfn "releases/$release_id" "$current.tmp" || return $?
  mv -Tf "$current.tmp" "$current" || return $?
}

snapshot_deploy_pointers() {
  local out="$1" link
  : > "$out" || return $?
  for link in "$CURRENT_WEB_LINK" "$PREVIOUS_WEB_LINK" "$CURRENT_RUNTIME_LINK" "$PREVIOUS_RUNTIME_LINK"; do
    if [ -L "$link" ]; then
      local target
      target="$(readlink "$link")" || return $?
      printf '%s\t%s\n' "$link" "$target" >> "$out" || return $?
    else
      printf '%s\t\n' "$link" >> "$out" || return $?
    fi
  done
}

restore_deploy_pointers() {
  local snapshot="$1" link target
  [ -f "$snapshot" ] || return 0
  while IFS=$'\t' read -r link target; do
    case "$link" in "$CONTROL_ROOT"/*) ;; *) die "unsafe pointer snapshot entry: $link" ;; esac
    if [ -n "${target:-}" ]; then ln -sfn "$target" "$link.tmp"; mv -Tf "$link.tmp" "$link"; else rm -f "$link" "$link.tmp"; fi
  done < "$snapshot"
}

restore_component_pointer_snapshot() {
  local snapshot="$1" component="$2" link target
  [ -f "$snapshot" ] || return 1
  while IFS=$'\t' read -r link target; do
    case "$component:$link" in
      web:"$CURRENT_WEB_LINK"|web:"$PREVIOUS_WEB_LINK"|runtime:"$CURRENT_RUNTIME_LINK"|runtime:"$PREVIOUS_RUNTIME_LINK") ;;
      *) continue ;;
    esac
    if [ -n "${target:-}" ]; then
      ln -sfn "$target" "$link.tmp" || return $?
      mv -Tf "$link.tmp" "$link" || return $?
    else
      rm -f "$link" "$link.tmp" || return $?
    fi
  done < "$snapshot" || return $?
}

deploy_stage_set() {
  printf '%s=1\n' "$2" >> "$1" || return $?
  sync -f "$1" 2>/dev/null || return $?
}
deploy_stage_has() { grep -qx "$2=1" "$1" 2>/dev/null; }
deploy_journal_set_value() {
  printf '%s=%s\n' "$2" "$3" >> "$1" || return $?
  sync -f "$1" 2>/dev/null || return $?
}
deploy_journal_value() { sed -n "s/^$2=//p" "$1" 2>/dev/null | tail -1; }
write_deploy_recovery_job() {
  local job_id="$1" target="$2" status="$3" message="$4"
  AGENTDECK_JOB_COMMAND=deploy AGENTDECK_JOB_TARGET="$target" AGENTDECK_JOB_LOG="$LOG_DIR/$job_id.log" write_job "$job_id" "$status" "$message"
}

cleanup_release_worktree() {
  local release_id="$1" release_path was_worktree=0
  [ -n "$release_id" ] || return 0
  valid_release_id "$release_id" || return 1
  release_path="$(release_path_for "$release_id")" || return $?
  clear_candidate_release_links "$release_path" || return $?
  if release_is_referenced "$release_path"; then log "cannot clean referenced failed release: $release_path"; return 1; else local reference_code=$?; [ "$reference_code" -eq 1 ] || return "$reference_code"; fi
  cd "$SOURCE_ROOT" || return 1
  if [ -e "$release_path" ]; then
    if [ -f "$release_path/.git" ]; then
      was_worktree=1
      run_as_service_user git -c "safe.directory=$SOURCE_ROOT" -C "$SOURCE_ROOT" worktree remove --force "$release_path" || return 1
    else
      rm -rf "$release_path" || return $?
    fi
  fi
  [ ! -e "$release_path" ] || return 1
  if [ "$was_worktree" = 1 ]; then run_as_service_user git -c "safe.directory=$SOURCE_ROOT" -C "$SOURCE_ROOT" worktree prune >/dev/null 2>&1 || true; fi
}

deploy_recover_once() {
  local job_id="$1" target="$2" pointer_snapshot="$3" stage_state="$4" code="$5"
  local failed_release_id="" recovery_failed=0 original_code
  [ -f "$stage_state" ] || return 0
  if deploy_stage_has "$stage_state" deploy_succeeded; then
    write_deploy_recovery_job "$job_id" "$target" succeeded "deploy succeeded (commit journal recovered)" || return $?
    return 0
  fi
  deploy_stage_has "$stage_state" recovery_completed && return 0
  original_code="$(deploy_journal_value "$stage_state" original_exit_code)" || return $?
  if [ -z "$original_code" ]; then deploy_journal_set_value "$stage_state" original_exit_code "$code" || return $?; fi
  if ! deploy_stage_has "$stage_state" recovery_started; then deploy_stage_set "$stage_state" recovery_started || return $?; fi
  undrain_runtime || return $?
  failed_release_id="$(deploy_journal_value "$stage_state" release_id)" || return $?
  if [ -z "$failed_release_id" ]; then
    failed_release_id="$(node - "$JOBS_DIR/$job_id.json" <<'NODE' 2>/dev/null || true
const fs=require('node:fs');try{const j=JSON.parse(fs.readFileSync(process.argv[2]));if(j.release)process.stdout.write(String(j.release));}catch{}
NODE
)"
  fi
  if deploy_stage_has "$stage_state" runtime_pointer_switch_started; then
    if ! deploy_stage_has "$stage_state" runtime_pointer_restore_completed; then
      if ! deploy_stage_has "$stage_state" runtime_pointer_restore_started; then deploy_stage_set "$stage_state" runtime_pointer_restore_started || return $?; fi
      log "deploy failed; restoring Runtime release pointers"
      if restore_component_pointer_snapshot "$pointer_snapshot" runtime; then deploy_stage_set "$stage_state" runtime_pointer_restore_completed || return $?; else recovery_failed=1; fi
    fi
    if [ "$recovery_failed" = 0 ] && deploy_stage_has "$stage_state" runtime_restart_started && ! deploy_stage_has "$stage_state" runtime_restart_recovery_completed; then
      if ! deploy_stage_has "$stage_state" runtime_restart_recovery_started; then deploy_stage_set "$stage_state" runtime_restart_recovery_started || return $?; fi
      if systemctl restart agentdeck-runtime.service && wait_http "http://127.0.0.1:$RUNTIME_PORT/healthz" 45; then deploy_stage_set "$stage_state" runtime_restart_recovery_completed || return $?; else recovery_failed=1; fi
    fi
  fi
  if [ "$recovery_failed" = 0 ] && deploy_stage_has "$stage_state" web_pointer_switch_started; then
    if ! deploy_stage_has "$stage_state" web_pointer_restore_completed; then
      if ! deploy_stage_has "$stage_state" web_pointer_restore_started; then deploy_stage_set "$stage_state" web_pointer_restore_started || return $?; fi
      log "deploy failed; restoring Web release pointers"
      if restore_component_pointer_snapshot "$pointer_snapshot" web; then deploy_stage_set "$stage_state" web_pointer_restore_completed || return $?; else recovery_failed=1; fi
    fi
    if [ "$recovery_failed" = 0 ] && deploy_stage_has "$stage_state" web_restart_started && ! deploy_stage_has "$stage_state" web_restart_recovery_completed; then
      if ! deploy_stage_has "$stage_state" web_restart_recovery_started; then deploy_stage_set "$stage_state" web_restart_recovery_started || return $?; fi
      if systemctl restart agentdeck-web.service && wait_http "http://127.0.0.1:$WEB_PORT/api/status" 45; then deploy_stage_set "$stage_state" web_restart_recovery_completed || return $?; else recovery_failed=1; fi
    fi
  fi
  if [ "$recovery_failed" = "1" ]; then
    deploy_stage_set "$stage_state" recovery_failed || return $?
    write_deploy_recovery_job "$job_id" "$target" failed "FATAL: deploy failed (exit $code) and old-version recovery failed; diagnostic state preserved" || return $?
    log "FATAL: old-version recovery failed after original deploy exit $code; preserving $pointer_snapshot, $stage_state and failed release"
    return 70
  fi
  write_deploy_recovery_job "$job_id" "$target" failed "deploy failed (exit $code); recovery cleanup in progress" || return $?
  if [ -n "$failed_release_id" ] && ! deploy_stage_has "$stage_state" release_cleanup_completed; then
    if ! deploy_stage_has "$stage_state" release_cleanup_started; then deploy_stage_set "$stage_state" release_cleanup_started || return $?; fi
    if cleanup_release_worktree "$failed_release_id"; then
      deploy_stage_set "$stage_state" release_cleanup_completed || return $?
    else
      deploy_stage_set "$stage_state" release_cleanup_failed || return $?
      write_deploy_recovery_job "$job_id" "$target" failed "FATAL: deploy failed (exit $code) and failed release cleanup is incomplete; diagnostic state preserved" || return $?
      return 70
    fi
  fi
  deploy_stage_set "$stage_state" recovery_completed || return $?
  write_deploy_recovery_job "$job_id" "$target" failed "deploy failed (exit $code); started operations recovered" || return $?
  return 0
}

deploy_worker_exit_trap() {
  local code="$1" job_id="$2" target="$3" pointer_snapshot="$4" stage_state="$5" recovery_code=0
  trap - EXIT HUP INT TERM
  cleanup_candidate_job "${AGENTDECK_CANDIDATE_JOB_ID:-}" || true
  if [ -f "$stage_state" ] && deploy_stage_has "$stage_state" deploy_succeeded; then
    write_deploy_recovery_job "$job_id" "$target" succeeded "deploy succeeded (commit journal authoritative)" || true
    code=0
  elif [ "$code" -ne 0 ]; then
    if [ ! -f "$stage_state" ]; then
      write_deploy_recovery_job "$job_id" "$target" failed "deploy failed before journal initialization (exit $code)" || true
    else
    deploy_recover_once "$job_id" "$target" "$pointer_snapshot" "$stage_state" "$code" || recovery_code=$?
    [ "$recovery_code" -eq 70 ] && code=70
    fi
  fi
  exit "$code"
}

recover_incomplete_deploy_journals() {
  local stage_state job_id pointer_snapshot target code status metadata
  for stage_state in "$STATE_DIR"/*.stages; do
    [ -f "$stage_state" ] || continue
    job_id="$(basename "$stage_state" .stages)"
    pointer_snapshot="$STATE_DIR/$job_id.pointers"
    metadata="$(node - "$JOBS_DIR/$job_id.json" <<'NODE' 2>/dev/null
const fs=require('node:fs');try{const j=JSON.parse(fs.readFileSync(process.argv[2]));process.stdout.write(`${j.target||'all'} ${j.status||'running'}`)}catch{process.exit(1)}
NODE
)" || return $?
    read -r target status <<< "$metadata" || return $?
    target="${target:-all}"
    if deploy_stage_has "$stage_state" deploy_succeeded; then
      if [ "$status" != succeeded ]; then write_deploy_recovery_job "$job_id" "$target" succeeded "deploy succeeded (commit journal recovered)" || return $?; fi
      rm -f "$pointer_snapshot" "$stage_state" || return $?
      continue
    fi
    deploy_stage_has "$stage_state" recovery_completed && continue
    code="$(deploy_journal_value "$stage_state" original_exit_code)" || return $?; code="${code:-1}"
    deploy_recover_once "$job_id" "$target" "$pointer_snapshot" "$stage_state" "$code" || return $?
  done
}

release_is_referenced() {
  local release="$1" link job job_release target
  release="$(realpath -m "$release")" || return 2
  for link in "$CURRENT_LINK" "$PREVIOUS_LINK" "$CANDIDATE_LINK" "$CURRENT_WEB_LINK" "$PREVIOUS_WEB_LINK" "$CANDIDATE_WEB_LINK" "$CURRENT_RUNTIME_LINK" "$PREVIOUS_RUNTIME_LINK" "$CANDIDATE_RUNTIME_LINK"; do
    [ -L "$link" ] || continue
    local raw_target
    raw_target="$(readlink "$link")" || return 2
    target="$(realpath -m "$(dirname "$link")/$raw_target")" || return 2
    [ "$target" = "$release" ] && return 0
  done
  for job in "$JOBS_DIR"/*.json; do
    [ -f "$job" ] || continue
    read -r job_release < <(node -e 'const j=JSON.parse(require("fs").readFileSync(process.argv[1]));if(["accepted","running"].includes(j.status)&&j.release)process.stdout.write(j.release)' "$job" 2>/dev/null || true)
    [ -n "${job_release:-}" ] && [ "$(realpath -m "$RELEASES_DIR/$job_release")" = "$release" ] && return 0
  done
  return 1
}

remove_release_if_unreferenced() {
  local release="$1"
  release_is_referenced "$release" && { log "keeping referenced release: $release"; return 0; }
  safe_rm_tree "$release" "$RELEASES_DIR"
}

clear_candidate_release_links() {
  local release="$1" link link_target resolved
  release="$(realpath -m "$release")" || return $?
  for link in "$CANDIDATE_LINK" "$CANDIDATE_WEB_LINK" "$CANDIDATE_RUNTIME_LINK"; do
    [ -L "$link" ] || continue
    link_target="$(readlink "$link")" || return $?
    resolved="$(realpath -m "$(dirname "$link")/$link_target")" || return $?
    if [ "$resolved" = "$release" ]; then rm -f "$link" || return $?; fi
  done
}
rollback_component(){ local component="$1" current previous current_target previous_target; if [ "$component" = web ];then current="$CURRENT_WEB_LINK";previous="$PREVIOUS_WEB_LINK";else current="$CURRENT_RUNTIME_LINK";previous="$PREVIOUS_RUNTIME_LINK";fi; [ -L "$previous" ]||die "previous $component release is not set";previous_target="$(readlink "$previous")";current_target="$(readlink "$current" 2>/dev/null||true)";ln -sfn "$previous_target" "$current.tmp";mv -Tf "$current.tmp" "$current";[ -z "$current_target" ]||{ ln -sfn "$current_target" "$previous.tmp";mv -Tf "$previous.tmp" "$previous";}; }

cleanup_releases() {
  ls -1dt "$RELEASES_DIR"/* 2>/dev/null | tail -n +"$((KEEP_RELEASES + 1))" | while read -r old; do
    remove_release_if_unreferenced "$old"
  done
}

drain_runtime() {
  curl -fsS -X POST -H 'content-type: application/json' --data "{\"ttlMs\":$((DRAIN_LEASE_SECONDS * 1000))}" "http://127.0.0.1:$RUNTIME_PORT/admin/runtime/drain" >/dev/null
}

undrain_runtime() {
  curl -fsS -X POST "http://127.0.0.1:$RUNTIME_PORT/admin/runtime/undrain" >/dev/null || true
}

wait_drain() {
  local force="$1" start state drained
  start="$(date +%s)"
  while true; do
    if ! state="$(drain_status 2>&1)"; then
      undrain_runtime
      echo "ERROR: runtime drain-status query failed during drain: $state" >&2
      return 1
    fi
    if ! drained="$(printf '%s' "$state" | drained_from_json)"; then
      undrain_runtime
      echo "ERROR: runtime drain-status response was invalid during drain" >&2
      return 1
    fi
    [ "$drained" = "true" ] && return 0
    drain_runtime
    if [ $(( $(date +%s) - start )) -ge "$DRAIN_TIMEOUT_SECONDS" ]; then
      undrain_runtime
      echo "ERROR: runtime drain timed out before drained=true; deployment cancelled" >&2
      return 1
    fi
    sleep 5
  done
}

require_runtime_drained() {
  local state drained
  if ! state="$(drain_status 2>&1)" || ! drained="$(printf '%s' "$state" | drained_from_json)" || [ "$drained" != "true" ]; then
    undrain_runtime
    echo "ERROR: final runtime drain check was not drained=true; deployment cancelled before restart" >&2
    return 1
  fi
}

reject_active_turns() {
  local turns count
  if ! turns="$(active_turns 2>&1)"; then
    die "runtime active-turn query failed; refusing unsafe restart: $turns"
  fi
  if ! count="$(printf '%s' "$turns" | active_turn_count_from_json)"; then
    die "runtime active-turn response was invalid; refusing unsafe restart"
  fi
  [ "$count" = "0" ] && return 0
  echo "ERROR: active turn exists ($count)." >&2
  printf '%s\n' "$turns" | node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{const j=JSON.parse(s); for (const t of j.turns||[]) console.error(`session=${t.sessionId} turn=${t.turnId || "-"} provider=${t.provider} runningMs=${t.runningMs}`);})'
  echo "Use a safe deploy instead: sudo agentdeckctl deploy runtime --wait" >&2
  return 2
}

restart_target() {
  local target="$1" force="${2:-0}"
  case "$target" in
    web)
      systemctl restart agentdeck-web.service
      wait_http "http://127.0.0.1:$WEB_PORT/api/status" 30
      ;;
    runtime)
      [ "$force" = "1" ] || reject_active_turns
      [ "$force" = "1" ] && log "forcing runtime restart; active turns may be interrupted"
      systemctl restart agentdeck-runtime.service
      wait_http "http://127.0.0.1:$RUNTIME_PORT/healthz" 30
      ;;
    all)
      drain_runtime
      if [ "$force" = "1" ]; then log "forcing all restart; active turns may be interrupted"; else wait_drain 0; require_runtime_drained; fi
      systemctl restart agentdeck-runtime.service
      wait_http "http://127.0.0.1:$RUNTIME_PORT/healthz" 30
      systemctl restart agentdeck-web.service
      wait_http "http://127.0.0.1:$WEB_PORT/api/status" 30
      ;;
    *) die "unknown restart target: $target" ;;
  esac
}

worker_deploy() {
  local job_id="$1" target="$2" force="$3"
  local pointer_snapshot="$STATE_DIR/$job_id.pointers"
  local stage_state="$STATE_DIR/$job_id.stages"
  export AGENTDECK_JOB_COMMAND=deploy AGENTDECK_JOB_TARGET="$target" AGENTDECK_JOB_LOG="$LOG_DIR/$job_id.log"
  exec >>"$LOG_DIR/$job_id.log" 2>&1
  write_job "$job_id" running "deploy started"
  export AGENTDECK_CANDIDATE_JOB_ID="$job_id"
  trap 'exit 129' HUP
  trap 'exit 130' INT
  trap 'exit 143' TERM
  trap 'deploy_worker_exit_trap "$?" "'$job_id'" "'$target'" "'$pointer_snapshot'" "'$stage_state'"' EXIT
  exec 9>"$LOCK_FILE"
  flock -n 9 || return $?
  recover_incomplete_deploy_journals || return $?
  local release_id release_path
  : > "$stage_state" || return $?
  snapshot_deploy_pointers "$pointer_snapshot" || return $?
  sync -f "$pointer_snapshot" 2>/dev/null || return $?
    if [ "$target" = runtime ] || [ "$target" = all ]; then verify_runtime_systemd_contract "$SYSTEMD_UNIT_VERSION" || exit $?; fi
    make_release "$stage_state" "$job_id" || exit $?
    deploy_stage_set "$stage_state" release_built || return $?
    release_id="$CREATED_RELEASE_ID"
    release_path="$(release_path_for "$release_id")"
    if [ "$target" = web ]||[ "$target" = all ];then ln -sfn "releases/$release_id" "$CANDIDATE_WEB_LINK";fi
    if [ "$target" = runtime ]||[ "$target" = all ];then ln -sfn "releases/$release_id" "$CANDIDATE_RUNTIME_LINK";fi
    export AGENTDECK_JOB_RELEASE="$release_id"
    write_job "$job_id" running "release built"
    assert_release_unit_requirement "$release_path" || exit $?
    check_systemd_units "$release_path" warn || true
    local candidate_runtime_release
    if [ "$target" = "runtime" ] || [ "$target" = "all" ]; then
      start_candidate_runtime "$release_path" "$job_id" || exit $?
      candidate_runtime_release="$release_id"
      [ "$target" != "runtime" ] || validate_candidate_runtime_compatibility || exit $?
    elif [ "$target" = "web" ]; then
      local current_runtime_release_path
      current_runtime_release_path="$(release_target "$CURRENT_RUNTIME_LINK")"
      [ -n "$current_runtime_release_path" ] || die "web-only validation requires current-runtime"
      start_candidate_runtime "$current_runtime_release_path" "$job_id" || exit $?
      candidate_runtime_release="$(basename "$current_runtime_release_path")"
    fi
    if [ "$target" = "web" ] || [ "$target" = "all" ]; then
      start_candidate_web "$release_path" "$job_id" "$candidate_runtime_release" || exit $?
    fi
    if [ "$target" = "runtime" ] || [ "$target" = "all" ]; then
      drain_runtime || exit $?
      if ! wait_drain "$force"; then exit 1; fi
      if ! require_runtime_drained; then exit 1; fi
      deploy_stage_set "$stage_state" runtime_pointer_switch_started || return $?
      switch_component runtime "$release_id" || return $?
      deploy_stage_set "$stage_state" runtime_pointer_switch_completed || return $?
      deploy_stage_set "$stage_state" runtime_restart_started || return $?
      systemctl restart agentdeck-runtime.service || return $?
      deploy_stage_set "$stage_state" runtime_restart_completed || return $?
      wait_http "http://127.0.0.1:$RUNTIME_PORT/healthz" 45 || exit $?
    else
      deploy_stage_set "$stage_state" web_pointer_switch_started || return $?
      switch_component web "$release_id" || return $?
      deploy_stage_set "$stage_state" web_pointer_switch_completed || return $?
    fi
    if [ "$target" = "web" ] || [ "$target" = "all" ]; then
      if [ "$target" = "all" ]; then
        deploy_stage_set "$stage_state" web_pointer_switch_started || return $?
        switch_component web "$release_id" || return $?
        deploy_stage_set "$stage_state" web_pointer_switch_completed || return $?
      fi
      deploy_stage_set "$stage_state" web_restart_started || return $?
      systemctl restart agentdeck-web.service || return $?
      deploy_stage_set "$stage_state" web_restart_completed || return $?
      wait_http "http://127.0.0.1:$WEB_PORT/api/status" 45 || exit $?
    fi
  clear_candidate_release_links "$release_path" || return $?
  cleanup_releases || return $?
  deploy_stage_set "$stage_state" deploy_succeeded || return $?
  write_job "$job_id" succeeded "deploy succeeded" || return $?
  rm -f "$pointer_snapshot" "$stage_state" || return $?
}

worker_rollback() {
  local job_id="$1" target="$2" force="$3"
  export AGENTDECK_JOB_COMMAND=rollback AGENTDECK_JOB_TARGET="$target" AGENTDECK_JOB_LOG="$LOG_DIR/$job_id.log"
  exec >>"$LOG_DIR/$job_id.log" 2>&1
  write_job "$job_id" running "rollback started"
  (
    flock -n 9 || die "another deploy/rollback job is running"
    local previous_target current_target
    if [ "$target" = "runtime" ] || [ "$target" = "all" ]; then
      drain_runtime
      wait_drain "$force"
      require_runtime_drained
    fi
    if [ "$target" = runtime ]||[ "$target" = all ];then rollback_component runtime;fi
    if [ "$target" = web ]||[ "$target" = all ];then rollback_component web;fi
    if [ "$target" = "runtime" ] || [ "$target" = "all" ]; then
      systemctl restart agentdeck-runtime.service
      wait_http "http://127.0.0.1:$RUNTIME_PORT/healthz" 45
    fi
    if [ "$target" = "web" ] || [ "$target" = "all" ]; then
      systemctl restart agentdeck-web.service
      wait_http "http://127.0.0.1:$WEB_PORT/api/status" 45
    fi
    write_job "$job_id" succeeded "rollback succeeded"
  ) 9>"$LOCK_FILE" || {
    local code=$?
    undrain_runtime
    write_job "$job_id" failed "rollback failed"
    exit "$code"
  }
}

submit_job() {
  local command="$1" target="$2" wait="$3" force="$4" job_id log_file
  ensure_dirs
  cleanup_stale_candidate_jobs
  if [ "$wait" = "1" ] && [ "$force" != "1" ] && { [ "$target" = "runtime" ] || [ "$target" = "all" ]; }; then
    local turns count
    if turns="$(active_turns 2>/dev/null)" && count="$(printf '%s' "$turns" | active_turn_count_from_json 2>/dev/null)" && [ "$count" != "0" ]; then
      echo "ERROR: runtime has $count active turn(s); refusing --wait deploy to avoid self-wait." >&2
      echo "Run without --wait to let the deploy job drain asynchronously, or use --force to interrupt active turns." >&2
      return 2
    fi
  fi
  job_id="$command-$(date -u +%Y%m%d-%H%M%S)-$RANDOM"
  log_file="$LOG_DIR/$job_id.log"
  export AGENTDECK_JOB_COMMAND="$command" AGENTDECK_JOB_TARGET="$target" AGENTDECK_JOB_LOG="$log_file"
  write_job "$job_id" accepted "$command accepted"
  local worker_args=("$command" "$target" "--job-id=$job_id")
  [ "$force" = "1" ] && worker_args+=("--force")
  if command -v systemd-run >/dev/null 2>&1 && [ "${AGENTDECK_NO_SYSTEMD_RUN:-0}" != "1" ]; then
    local candidate_mode_args=()
    [ -z "${AGENTDECK_CANDIDATE_DB_MODE:-}" ] || candidate_mode_args+=("--setenv=AGENTDECK_CANDIDATE_DB_MODE=$AGENTDECK_CANDIDATE_DB_MODE")
    systemd-run --unit="agentdeck-deploy@$job_id" --collect --same-dir --property=WorkingDirectory="$SOURCE_ROOT" --setenv=AGENTDECK_DEPLOY_WORKER=1 --setenv=AGENTDECK_ROOT="$CONTROL_ROOT" --setenv=AGENTDECK_SOURCE_ROOT="$SOURCE_ROOT" --setenv=DATA_DIR="$DATA_DIR" --setenv=AGENTDECK_ENV_DIR="$ENV_DIR" "${candidate_mode_args[@]}" "$SOURCE_ROOT/scripts/agentdeckctl" "${worker_args[@]}" >/dev/null
  else
    AGENTDECK_DEPLOY_WORKER=1 "$SOURCE_ROOT/scripts/agentdeckctl" "${worker_args[@]}" >>"$log_file" 2>&1 &
  fi
  echo "$command job accepted: $job_id"
  echo "Track with:"
  echo "  sudo agentdeckctl job $job_id"
  echo "  sudo journalctl -fu agentdeck-deploy@$job_id.service"
  [ "$wait" = "1" ] && wait_job "$job_id"
}

wait_job() {
  local job_id="$1" status
  while true; do
    [ -f "$JOBS_DIR/$job_id.json" ] || die "job not found: $job_id"
    status="$(node -e 'const fs=require("fs"); console.log(JSON.parse(fs.readFileSync(process.argv[1],"utf8")).status)' "$JOBS_DIR/$job_id.json")"
    case "$status" in
      succeeded) return 0 ;;
      failed) return 1 ;;
      *) sleep 3 ;;
    esac
  done
}

if [ "${BASH_SOURCE[0]}" != "$0" ]; then return 0; fi
COMMAND="${1:-}"
[ -n "$COMMAND" ] || { usage; exit 2; }
shift || true
TARGET="${1:-}"
case "$COMMAND" in status|check|doctor|jobs|install-units|setup-units|backup) ;; *) shift || true ;; esac
WAIT=0
FORCE=0
JSON=0
INCLUDE_SECRETS=0
DRY_RUN=0
RUNTIME_DROP_IN=0
JOB_ID=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --wait) WAIT=1; shift ;;
    --force) FORCE=1; shift ;;
    --json) JSON=1; shift ;;
    --include-secrets) INCLUDE_SECRETS=1; shift ;;
    --dry-run) DRY_RUN=1; shift ;;
    --runtime-drop-in) RUNTIME_DROP_IN=1; shift ;;
    --job-id=*) JOB_ID="${1#--job-id=}"; shift ;;
    *) usage; exit 2 ;;
  esac
done

ensure_dirs
case "$COMMAND" in
  status) [ "$JSON" = "1" ] && status_json || status_text ;;
  check) run_check ;;
  doctor) run_doctor ;;
  install-units|setup-units) [ "$RUNTIME_DROP_IN" = 1 ] && run_install_units --runtime-drop-in || run_install_units ;;
  backup) run_backup "$INCLUDE_SECRETS" ;;
  restore) run_restore "$TARGET" "$DRY_RUN" "$FORCE" ;;
  restart) [ -n "$TARGET" ] || die "restart target required"; restart_target "$TARGET" "$FORCE" ;;
  deploy)
    TARGET="${TARGET:-all}"
    if is_worker; then worker_deploy "$JOB_ID" "$TARGET" "$FORCE"; else submit_job deploy "$TARGET" "$WAIT" "$FORCE"; fi
    ;;
  rollback)
    TARGET="${TARGET:-all}"
    if is_worker; then worker_rollback "$JOB_ID" "$TARGET" "$FORCE"; else submit_job rollback "$TARGET" "$WAIT" "$FORCE"; fi
    ;;
  jobs) list_jobs ;;
  job) [ -n "$TARGET" ] || die "job id required"; show_job "$TARGET" ;;
  logs) [ "$TARGET" = "deploy" ] || die "only logs deploy is supported"; tail -n 200 -F "$LOG_DIR"/*.log ;;
  *) usage; exit 2 ;;
esac
