{
  "name": "agentdeck",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p server/tsconfig.json",
    "build:client": "vite build --config client/vite.config.ts",
    "typecheck": "npm run build:server",
    "lint": "tsc -p server/tsconfig.json --noEmit && vite build --config client/vite.config.ts --mode lint",
    "test": "node --test tests/*.test.mjs",
    "test:e2e": "node --test tests/e2e/*.test.mjs",
    "start": "node server/dist/index.js",
    "runtime": "node server/dist/agentdeck-runtime.js",
    "dev": "tsx server/src/index.ts",
    "dev:runtime": "tsx server/src/agentdeck-runtime.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^6.12.0",
    "@fastify/websocket": "^8.3.1",
    "argon2": "^0.43.1",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.6.1",
    "fastify": "^4.28.1",
    "node-pty": "^1.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.34",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  }
}
